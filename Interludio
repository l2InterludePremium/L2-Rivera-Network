        }

        h1 {
            color: #cfb53b;
            font-size: 3.5rem;
            margin: 0;
            text-shadow: 0 0 15px rgba(207, 181, 59, 0.6);
            letter-spacing: 2px;
        }

        .contenido {
            padding: 50px 20px;
            max-width: 850px;
            margin: auto;
            text-align: center;
            position: relative;
        }

        .btn {
            background: linear-gradient(135deg, #cfb53b, #8a7526);
            color: #000 !important;
            padding: 18px 35px;
            text-decoration: none;
            font-weight: bold;
            border-radius: 8px;
            display: inline-block;
            margin-top: 30px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.5);
            transition: 0.3s;
            text-transform: uppercase;
        }

        .btn:hover {
            background: #fff !important;
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(207, 181, 59, 0.4);
        }

        .highlight {
            color: #cfb53b;
            font-weight: bold;
        }

        p {
            line-height: 1.6;
            font-size: 1.15rem;
        }
    </style>
</head>
